# --- LLM backend selection ---
# rocm_vllm (default, primary/on-prem) | fireworks (opt-in cloud triage) | local_dev (offline iteration only, never demoed)
KLAUS_LLM_BACKEND=rocm_vllm

# --- ROCmVLLMBackend: primary, on-prem (vLLM serving Qwen3 on an AMD Radeon/RDNA3 instance) ---
ROCM_VLLM_BASE_URL=http://localhost:8000/v1
ROCM_VLLM_MODEL=Qwen/Qwen3-14B

# --- FireworksGemmaBackend: opt-in cloud triage tier, never the default ---
KLAUS_ALLOW_CLOUD_TRIAGE=false
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/gemma-4-31b-it

# --- LocalDevBackend: offline iteration only, via Ollama, never used in the live demo ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:2b
